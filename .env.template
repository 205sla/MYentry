# CODE 205 환경 변수 템플릿
# 이 파일을 `.env`로 복사한 뒤 실제 값을 채워 넣으세요.
# `.env`는 gitignore 대상이므로 커밋되지 않습니다.

# ─────── 서버 ───────
# 리스닝 포트 (미지정 시 3000)
PORT=3000

# 사이트 절대 URL (sitemap.xml·OG 태그에 사용)
SITE_URL=https://code.205.kr

# ─────── 세션 (Phase 2에서 활성화 예정) ───────
# express-session 서명 키. 충분히 긴 무작위 문자열로 설정하세요.
#   Windows PowerShell: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
#   Git Bash:           openssl rand -base64 48
SESSION_SECRET=change-me-to-long-random-string

# 세션 쿠키 보안 모드 (HTTPS 뒤에 배포할 때만 true)
SESSION_COOKIE_SECURE=false

# ─────── DB (Phase 2에서 활성화 예정) ───────
# SQLite 파일 경로 (저장소 내부 db/ 디렉터리 권장 — gitignore 대상)
DB_PATH=./db/data.db
