node_modules/
# Claude Code config (skills 포함 전체 로컬 유지)
.claude/
*.key
*.pem
*.pub
deploy-key

# Local-only reference docs (Entry official docs mirror — not committed)
docs/
.tmp-entrydocs/

# Legacy problems archived locally (old-style, not served)
old/

# Local scratch/temp directory
temp/

# Environment secrets (use .env.template as reference)
.env
.env.local

# Runtime data: SQLite DB, user uploads 등 (db/ 구조는 .gitkeep로 유지)
db/*
!db/.gitkeep

# PM2 log files — ecosystem.config.js가 logs/entry-*.log로 출력
logs/*
!logs/.gitkeep
