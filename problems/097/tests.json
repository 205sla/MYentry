{
  "test": [
    {
      "name": "[1,2,3,4]-[2,4] → [1,3]",
      "setup": { "lists": { "A": [1, 2, 3, 4], "B": [2, 4], "차집합": [] } },
      "expected": { "lists": { "차집합": [1, 3] } }
    },
    {
      "name": "중복 A",
      "setup": { "lists": { "A": [1, 1, 2, 2], "B": [1], "차집합": [] } },
      "expected": { "lists": { "차집합": [2] } }
    },
    {
      "name": "A ⊆ B",
      "setup": { "lists": { "A": [1, 2], "B": [1, 2, 3], "차집합": [] } },
      "expected": { "lists": { "차집합": [] } }
    }
  ],
  "submit": [
    {
      "name": "B 빈 → A 중복 제거",
      "setup": { "lists": { "A": [1, 2, 1, 3], "B": [], "차집합": [] } },
      "expected": { "lists": { "차집합": [1, 2, 3] } }
    },
    {
      "name": "A 빈",
      "setup": { "lists": { "A": [], "B": [1, 2], "차집합": [] } },
      "expected": { "lists": { "차집합": [] } }
    },
    {
      "name": "완전 동일",
      "setup": { "lists": { "A": [1, 2, 3], "B": [1, 2, 3], "차집합": [] } },
      "expected": { "lists": { "차집합": [] } }
    },
    {
      "name": "공통 없음",
      "setup": { "lists": { "A": [1, 2, 3], "B": [4, 5, 6], "차집합": [] } },
      "expected": { "lists": { "차집합": [1, 2, 3] } }
    },
    {
      "name": "A 순서 유지",
      "setup": { "lists": { "A": [5, 3, 1, 4, 2], "B": [3, 4], "차집합": [] } },
      "expected": { "lists": { "차집합": [5, 1, 2] } }
    },
    {
      "name": "음수 차집합",
      "setup": { "lists": { "A": [-1, 0, 1], "B": [0], "차집합": [] } },
      "expected": { "lists": { "차집합": [-1, 1] } }
    },
    {
      "name": "큰 A, 작은 B",
      "setup": { "lists": { "A": [1, 2, 3, 4, 5], "B": [2, 4], "차집합": [] } },
      "expected": { "lists": { "차집합": [1, 3, 5] } }
    },
    {
      "name": "A 중복 많음",
      "setup": { "lists": { "A": [1, 1, 1, 2, 2], "B": [2], "차집합": [] } },
      "expected": { "lists": { "차집합": [1] } }
    },
    {
      "name": "B 커서 많이 제거",
      "setup": { "lists": { "A": [1, 2, 3], "B": [1, 2, 3, 4, 5], "차집합": [] } },
      "expected": { "lists": { "차집합": [] } }
    },
    {
      "name": "A 반 남음",
      "setup": { "lists": { "A": [1, 2, 3, 4, 5, 6, 7, 8], "B": [2, 4, 6, 8], "차집합": [] } },
      "expected": { "lists": { "차집합": [1, 3, 5, 7] } }
    }
  ]
}
