{
  "test": [
    {
      "name": "전체 양수 [1,2,3] → 6",
      "setup": { "lists": { "숫자들": [1, 2, 3] } },
      "expected": { "say": ["6"] }
    },
    {
      "name": "모두 음수 [-1,-2,-3] → -1",
      "setup": { "lists": { "숫자들": [-1, -2, -3] } },
      "expected": { "say": ["-1"] }
    },
    {
      "name": "고전 예제 [-2,1,-3,4,-1,2,1,-5,4] → 6",
      "setup": { "lists": { "숫자들": [-2, 1, -3, 4, -1, 2, 1, -5, 4] } },
      "expected": { "say": ["6"] }
    }
  ],
  "submit": [
    {
      "name": "단일 양수 [5]",
      "setup": { "lists": { "숫자들": [5] } },
      "expected": { "say": ["5"] }
    },
    {
      "name": "단일 음수 [-5]",
      "setup": { "lists": { "숫자들": [-5] } },
      "expected": { "say": ["-5"] }
    },
    {
      "name": "모두 0 [0,0,0]",
      "setup": { "lists": { "숫자들": [0, 0, 0] } },
      "expected": { "say": ["0"] }
    },
    {
      "name": "선두 음수 스킵 [-1,2,3,-4,5] → 6",
      "setup": { "lists": { "숫자들": [-1, 2, 3, -4, 5] } },
      "expected": { "say": ["6"] }
    },
    {
      "name": "교대 [1,-1,1,-1,1] → 1",
      "setup": { "lists": { "숫자들": [1, -1, 1, -1, 1] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "다중 구간 비교 [-2,-3,4,-1,-2,1,5,-3] → 7",
      "setup": { "lists": { "숫자들": [-2, -3, 4, -1, -2, 1, 5, -3] } },
      "expected": { "say": ["7"] }
    },
    {
      "name": "전부 음수 내림차순 [-5,-4,-3,-2,-1] → -1",
      "setup": { "lists": { "숫자들": [-5, -4, -3, -2, -1] } },
      "expected": { "say": ["-1"] }
    },
    {
      "name": "초반 피크 [10,-1,-1,-1] → 10",
      "setup": { "lists": { "숫자들": [10, -1, -1, -1] } },
      "expected": { "say": ["10"] }
    },
    {
      "name": "큰 음수로 분단 [3,-10,4,5] → 9",
      "setup": { "lists": { "숫자들": [3, -10, 4, 5] } },
      "expected": { "say": ["9"] }
    },
    {
      "name": "최적 구간이 앞쪽 [2,3,5,-10,1,2] → 10",
      "setup": { "lists": { "숫자들": [2, 3, 5, -10, 1, 2] } },
      "expected": { "say": ["10"] }
    }
  ]
}
