{
  "test": [
    {
      "name": "[6] → [12]",
      "setup": { "lists": { "숫자들": [6], "합들": [] } },
      "expected": { "lists": { "합들": [12] } }
    },
    {
      "name": "[1,6,10] → [1,12,18]",
      "setup": { "lists": { "숫자들": [1, 6, 10], "합들": [] } },
      "expected": { "lists": { "합들": [1, 12, 18] } }
    },
    {
      "name": "[12] → [28]",
      "setup": { "lists": { "숫자들": [12], "합들": [] } },
      "expected": { "lists": { "합들": [28] } }
    }
  ],
  "submit": [
    {
      "name": "빈 리스트",
      "setup": { "lists": { "숫자들": [], "합들": [] } },
      "expected": { "lists": { "합들": [] } }
    },
    {
      "name": "소수들 (합 = N+1)",
      "setup": { "lists": { "숫자들": [2, 3, 5, 7, 11], "합들": [] } },
      "expected": { "lists": { "합들": [3, 4, 6, 8, 12] } }
    },
    {
      "name": "제곱수",
      "setup": { "lists": { "숫자들": [4, 9, 16, 25], "합들": [] } },
      "expected": { "lists": { "합들": [7, 13, 31, 31] } }
    },
    {
      "name": "완전수 28",
      "setup": { "lists": { "숫자들": [28], "합들": [] } },
      "expected": { "lists": { "합들": [56] } }
    },
    {
      "name": "1~5",
      "setup": { "lists": { "숫자들": [1, 2, 3, 4, 5], "합들": [] } },
      "expected": { "lists": { "합들": [1, 3, 4, 7, 6] } }
    },
    {
      "name": "중복",
      "setup": { "lists": { "숫자들": [6, 6, 6], "합들": [] } },
      "expected": { "lists": { "합들": [12, 12, 12] } }
    },
    {
      "name": "큰 수 100",
      "setup": { "lists": { "숫자들": [100], "합들": [] } },
      "expected": { "lists": { "합들": [217] } }
    },
    {
      "name": "8",
      "setup": { "lists": { "숫자들": [8], "합들": [] } },
      "expected": { "lists": { "합들": [15] } }
    },
    {
      "name": "24",
      "setup": { "lists": { "숫자들": [24], "합들": [] } },
      "expected": { "lists": { "합들": [60] } }
    },
    {
      "name": "순서 유지",
      "setup": { "lists": { "숫자들": [5, 3, 8], "합들": [] } },
      "expected": { "lists": { "합들": [6, 4, 15] } }
    }
  ]
}
