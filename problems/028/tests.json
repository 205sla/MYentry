{
  "test": [
    {
      "name": "단일 항목 [5]",
      "setup": { "lists": { "숫자들": [5] } },
      "expected": { "say": ["5"] }
    },
    {
      "name": "동률 [1,1,2,2] → 1 (작은 값)",
      "setup": { "lists": { "숫자들": [1, 1, 2, 2] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "단일 최빈값 [1,2,2,3,3,3] → 3",
      "setup": { "lists": { "숫자들": [1, 2, 2, 3, 3, 3] } },
      "expected": { "say": ["3"] }
    }
  ],
  "submit": [
    {
      "name": "모두 같은 값",
      "setup": { "lists": { "숫자들": [7, 7, 7, 7] } },
      "expected": { "say": ["7"] }
    },
    {
      "name": "모두 다른 값 (전부 1회) → 최소",
      "setup": { "lists": { "숫자들": [1, 2, 3, 4] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "중간 피크",
      "setup": { "lists": { "숫자들": [1, 2, 2, 2, 3] } },
      "expected": { "say": ["2"] }
    },
    {
      "name": "2-way 동률",
      "setup": { "lists": { "숫자들": [1, 1, 1, 2, 2, 2] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "3-way 동률",
      "setup": { "lists": { "숫자들": [1, 1, 2, 2, 3, 3] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "음수 최빈값",
      "setup": { "lists": { "숫자들": [-1, -1, -2] } },
      "expected": { "say": ["-1"] }
    },
    {
      "name": "흩어진 데이터 → 5",
      "setup": { "lists": { "숫자들": [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5] } },
      "expected": { "say": ["5"] }
    },
    {
      "name": "0 포함 동률 → 0",
      "setup": { "lists": { "숫자들": [0, 0, 1, 1] } },
      "expected": { "say": ["0"] }
    },
    {
      "name": "2가 5번",
      "setup": { "lists": { "숫자들": [1, 1, 1, 1, 2, 2, 2, 2, 2] } },
      "expected": { "say": ["2"] }
    },
    {
      "name": "1이 3번",
      "setup": { "lists": { "숫자들": [1, 2, 3, 3, 2, 1, 1] } },
      "expected": { "say": ["1"] }
    }
  ]
}
