{
  "test": [
    {
      "name": "[5,3,2] → 3",
      "setup": { "lists": { "숫자들": [5, 3, 2] } },
      "expected": { "say": ["3"] }
    },
    {
      "name": "[10,20,30] → 20",
      "setup": { "lists": { "숫자들": [10, 20, 30] } },
      "expected": { "say": ["20"] }
    },
    {
      "name": "[7,7,7] → 7 (모두 동일)",
      "setup": { "lists": { "숫자들": [7, 7, 7] } },
      "expected": { "say": ["7"] }
    }
  ],
  "submit": [
    {
      "name": "두 항목 [1,2]",
      "setup": { "lists": { "숫자들": [1, 2] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "두 항목 [9,9]",
      "setup": { "lists": { "숫자들": [9, 9] } },
      "expected": { "say": ["9"] }
    },
    {
      "name": "[5,5,3] → 5 (중복)",
      "setup": { "lists": { "숫자들": [5, 5, 3] } },
      "expected": { "say": ["5"] }
    },
    {
      "name": "[5,3,5] → 5",
      "setup": { "lists": { "숫자들": [5, 3, 5] } },
      "expected": { "say": ["5"] }
    },
    {
      "name": "이미 정렬 [1,2,3,4,5]",
      "setup": { "lists": { "숫자들": [1, 2, 3, 4, 5] } },
      "expected": { "say": ["4"] }
    },
    {
      "name": "역순 [5,4,3,2,1]",
      "setup": { "lists": { "숫자들": [5, 4, 3, 2, 1] } },
      "expected": { "say": ["4"] }
    },
    {
      "name": "음수만",
      "setup": { "lists": { "숫자들": [-1, -2, -3] } },
      "expected": { "say": ["-2"] }
    },
    {
      "name": "음수+양수",
      "setup": { "lists": { "숫자들": [-5, 0, 5] } },
      "expected": { "say": ["0"] }
    },
    {
      "name": "큰 수 혼합",
      "setup": { "lists": { "숫자들": [100, 50, 200, 300, 150] } },
      "expected": { "say": ["200"] }
    },
    {
      "name": "단일 최대 독점",
      "setup": { "lists": { "숫자들": [999, 1, 1, 1, 1] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "피보나치",
      "setup": { "lists": { "숫자들": [1, 1, 2, 3, 5, 8, 13] } },
      "expected": { "say": ["8"] }
    }
  ]
}
