{
  "test": [
    {
      "name": "단순 쌍 () → 올바름",
      "setup": { "lists": { "괄호": ["(", ")"] } },
      "expected": { "say": ["올바름"] }
    },
    {
      "name": "역순 )( → 틀림",
      "setup": { "lists": { "괄호": [")", "("] } },
      "expected": { "say": ["틀림"] }
    },
    {
      "name": "중첩 3종 ([ ]) → 올바름",
      "setup": { "lists": { "괄호": ["(", "[", "]", ")"] } },
      "expected": { "say": ["올바름"] }
    }
  ],
  "submit": [
    {
      "name": "빈 리스트",
      "setup": { "lists": { "괄호": [] } },
      "expected": { "say": ["올바름"] }
    },
    {
      "name": "3중 중첩 ((()))",
      "setup": { "lists": { "괄호": ["(", "(", "(", ")", ")", ")"] } },
      "expected": { "say": ["올바름"] }
    },
    {
      "name": "병렬 ()()",
      "setup": { "lists": { "괄호": ["(", ")", "(", ")"] } },
      "expected": { "say": ["올바름"] }
    },
    {
      "name": "대괄호 안 소괄호 [()]",
      "setup": { "lists": { "괄호": ["[", "(", ")", "]"] } },
      "expected": { "say": ["올바름"] }
    },
    {
      "name": "짝 불일치 (]",
      "setup": { "lists": { "괄호": ["(", "]"] } },
      "expected": { "say": ["틀림"] }
    },
    {
      "name": "닫힘 하나 초과 (()))",
      "setup": { "lists": { "괄호": ["(", "(", ")", ")", ")"] } },
      "expected": { "say": ["틀림"] }
    },
    {
      "name": "열림 하나 남음 (()",
      "setup": { "lists": { "괄호": ["(", "(", ")"] } },
      "expected": { "say": ["틀림"] }
    },
    {
      "name": "3종 완전 중첩 {[()]}",
      "setup": { "lists": { "괄호": ["{", "[", "(", ")", "]", "}"] } },
      "expected": { "say": ["올바름"] }
    },
    {
      "name": "교차 { [ } ]",
      "setup": { "lists": { "괄호": ["{", "[", "}", "]"] } },
      "expected": { "say": ["틀림"] }
    },
    {
      "name": "3종 병렬 ()[]{}",
      "setup": { "lists": { "괄호": ["(", ")", "[", "]", "{", "}"] } },
      "expected": { "say": ["올바름"] }
    }
  ]
}
