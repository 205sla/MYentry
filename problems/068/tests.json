{
  "test": [
    {
      "name": "[3,1,4,1,5] → 1",
      "setup": { "lists": { "숫자들": [3, 1, 4, 1, 5] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "음수만 [-2,-5,-1] → -5",
      "setup": { "lists": { "숫자들": [-2, -5, -1] } },
      "expected": { "say": ["-5"] }
    },
    {
      "name": "단일 [42] → 42",
      "setup": { "lists": { "숫자들": [42] } },
      "expected": { "say": ["42"] }
    }
  ],
  "submit": [
    {
      "name": "이미 정렬",
      "setup": { "lists": { "숫자들": [1, 2, 3, 4, 5] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "역순",
      "setup": { "lists": { "숫자들": [5, 4, 3, 2, 1] } },
      "expected": { "say": ["1"] }
    },
    {
      "name": "모두 같은 값",
      "setup": { "lists": { "숫자들": [7, 7, 7, 7] } },
      "expected": { "say": ["7"] }
    },
    {
      "name": "0 포함",
      "setup": { "lists": { "숫자들": [3, 0, 5] } },
      "expected": { "say": ["0"] }
    },
    {
      "name": "첫 번째가 최소",
      "setup": { "lists": { "숫자들": [-100, 1, 2, 3] } },
      "expected": { "say": ["-100"] }
    },
    {
      "name": "마지막이 최소",
      "setup": { "lists": { "숫자들": [10, 20, 30, -100] } },
      "expected": { "say": ["-100"] }
    },
    {
      "name": "음수+양수",
      "setup": { "lists": { "숫자들": [5, -3, 8, -10] } },
      "expected": { "say": ["-10"] }
    },
    {
      "name": "두 항목",
      "setup": { "lists": { "숫자들": [9, 3] } },
      "expected": { "say": ["3"] }
    },
    {
      "name": "중복 최솟값",
      "setup": { "lists": { "숫자들": [5, 2, 2, 8] } },
      "expected": { "say": ["2"] }
    },
    {
      "name": "10개 흩어진",
      "setup": { "lists": { "숫자들": [50, 200, 300, 150, 10, 500, 400, 100, 250, 350] } },
      "expected": { "say": ["10"] }
    }
  ]
}
