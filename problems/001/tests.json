{
  "test": [
    {
      "name": "값 존재 (중간)",
      "setup": {
        "variables": { "대답": "5" },
        "lists": { "리스트": [3, 1, 5, 7, 9] }
      },
      "expected": {
        "say": ["5은 리스트의 3번 위치에 있습니다."]
      }
    },
    {
      "name": "값 미존재",
      "setup": {
        "variables": { "대답": "4" },
        "lists": { "리스트": [3, 1, 5, 7, 9] }
      },
      "expected": {
        "say": ["입력하신 값이 리스트에 없습니다."]
      }
    },
    {
      "name": "첫 번째 위치",
      "setup": {
        "variables": { "대답": "10" },
        "lists": { "리스트": [10, 20, 30] }
      },
      "expected": {
        "say": ["10은 리스트의 1번 위치에 있습니다."]
      }
    }
  ],
  "submit": [
    {
      "name": "중간값",
      "setup": {
        "variables": { "대답": "5" },
        "lists": { "리스트": [1, 3, 5, 7, 9] }
      },
      "expected": {
        "say": ["5은 리스트의 3번 위치에 있습니다."]
      }
    },
    {
      "name": "마지막값",
      "setup": {
        "variables": { "대답": "8" },
        "lists": { "리스트": [2, 4, 6, 8] }
      },
      "expected": {
        "say": ["8은 리스트의 4번 위치에 있습니다."]
      }
    },
    {
      "name": "미존재",
      "setup": {
        "variables": { "대답": "99" },
        "lists": { "리스트": [1, 2, 3] }
      },
      "expected": {
        "say": ["입력하신 값이 리스트에 없습니다."]
      }
    },
    {
      "name": "단일 원소 존재",
      "setup": {
        "variables": { "대답": "42" },
        "lists": { "리스트": [42] }
      },
      "expected": {
        "say": ["42은 리스트의 1번 위치에 있습니다."]
      }
    },
    {
      "name": "단일 원소 미존재",
      "setup": {
        "variables": { "대답": "7" },
        "lists": { "리스트": [42] }
      },
      "expected": {
        "say": ["입력하신 값이 리스트에 없습니다."]
      }
    },
    {
      "name": "첫 번째값 긴 리스트",
      "setup": {
        "variables": { "대답": "100" },
        "lists": { "리스트": [100, 200, 300, 400, 500] }
      },
      "expected": {
        "say": ["100은 리스트의 1번 위치에 있습니다."]
      }
    },
    {
      "name": "마지막값 긴 리스트",
      "setup": {
        "variables": { "대답": "70" },
        "lists": { "리스트": [10, 20, 30, 40, 50, 60, 70] }
      },
      "expected": {
        "say": ["70은 리스트의 7번 위치에 있습니다."]
      }
    },
    {
      "name": "중복값 첫 번째 발견",
      "setup": {
        "variables": { "대답": "5" },
        "lists": { "리스트": [5, 3, 5, 7, 5] }
      },
      "expected": {
        "say": ["5은 리스트의 1번 위치에 있습니다."]
      }
    },
    {
      "name": "큰 수 미존재",
      "setup": {
        "variables": { "대답": "66" },
        "lists": { "리스트": [11, 22, 33, 44, 55] }
      },
      "expected": {
        "say": ["입력하신 값이 리스트에 없습니다."]
      }
    },
    {
      "name": "두 번째 위치",
      "setup": {
        "variables": { "대답": "20" },
        "lists": { "리스트": [10, 20, 30, 40] }
      },
      "expected": {
        "say": ["20은 리스트의 2번 위치에 있습니다."]
      }
    }
  ]
}
