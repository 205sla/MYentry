{
  "test": [
    {
      "name": "[1,2,3] → 2",
      "setup": { "lists": { "숫자들": [1, 2, 3] } },
      "expected": { "say": ["2"] }
    },
    {
      "name": "[10,20,30,40,50] → 30",
      "setup": { "lists": { "숫자들": [10, 20, 30, 40, 50] } },
      "expected": { "say": ["30"] }
    },
    {
      "name": "단일 [5] → 5",
      "setup": { "lists": { "숫자들": [5] } },
      "expected": { "say": ["5"] }
    }
  ],
  "submit": [
    {
      "name": "모두 0",
      "setup": { "lists": { "숫자들": [0, 0, 0] } },
      "expected": { "say": ["0"] }
    },
    {
      "name": "모두 같은 값",
      "setup": { "lists": { "숫자들": [7, 7, 7, 7] } },
      "expected": { "say": ["7"] }
    },
    {
      "name": "두 수",
      "setup": { "lists": { "숫자들": [4, 10] } },
      "expected": { "say": ["7"] }
    },
    {
      "name": "음수만",
      "setup": { "lists": { "숫자들": [-1, -2, -3] } },
      "expected": { "say": ["-2"] }
    },
    {
      "name": "음수+양수",
      "setup": { "lists": { "숫자들": [-5, 0, 5] } },
      "expected": { "say": ["0"] }
    },
    {
      "name": "큰 수 5개",
      "setup": { "lists": { "숫자들": [100, 200, 300, 400, 500] } },
      "expected": { "say": ["300"] }
    },
    {
      "name": "9개 연속",
      "setup": { "lists": { "숫자들": [1, 2, 3, 4, 5, 6, 7, 8, 9] } },
      "expected": { "say": ["5"] }
    },
    {
      "name": "0 포함",
      "setup": { "lists": { "숫자들": [0, 10, 20] } },
      "expected": { "say": ["10"] }
    },
    {
      "name": "같은 합 다른 구성",
      "setup": { "lists": { "숫자들": [1, 5, 9] } },
      "expected": { "say": ["5"] }
    },
    {
      "name": "두 항목 평균",
      "setup": { "lists": { "숫자들": [2, 8] } },
      "expected": { "say": ["5"] }
    }
  ]
}
